        "jsCode": "const docs = $input.all();\n\nconst context = docs\n  .map(item => item.json.document.pageContent)\n  .join(\"\\n\\n\")\n  .replace(/\\n{3,}/g, \"\\n\\n\"); // remove excessive blank lines\n\nconst hasContext = context.length > 50; // adjust threshold\n\nreturn [{\n  json: {\n    chatInput: $('Code in JavaScript1').first().json.chatInput,\n    context,\n    hasContext,\n    sessionId: $('Code in JavaScript1').first().json.sessionId\n  }\n}];"
